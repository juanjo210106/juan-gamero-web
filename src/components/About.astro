---
// src/components/About.astro
import fotoTaller from '../assets/hero_metalica.png';
---

<section id="nosotros" class="about-section w-full bg-white overflow-hidden">
  <div class="about-inner max-w-[1400px] mx-auto px-8 md:px-16 flex flex-col md:flex-row">

    <!-- ══════════════════════════════════════════
         COLUMNA IZQUIERDA — sticky
         Label + Título enorme + Imagen con fade
    ═══════════════════════════════════════════ -->
    <div class="about-left md:w-[40%] flex-shrink-0 flex flex-col pt-20 pb-16 md:pr-16">

      <!-- • Nuestro Taller -->
      <p class="font-sans text-xs font-bold tracking-widest text-slate-900 uppercase mb-6 flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-slate-900"></span>
        Nuestro Taller
      </p>

      <!-- METAL QUE PERDURA. -->
      <h2 class="font-karma font-black text-slate-900 uppercase leading-none tracking-tighter mb-10 about-title" style="font-size: 70px;">
        METAL<br/>QUE PERDURA.
      </h2>

      <!-- Imagen: empieza casi negra, va aclarándose con el scroll -->
      <div class="about-img-wrapper w-full max-w-[380px] overflow-hidden">
        <img
          src={fotoTaller.src}
          alt="Taller de Carpintería Metálica Juan Gamero en Casariche"
          class="about-img w-full aspect-[3/4] object-cover block"
        />
      </div>

    </div>

    <!-- ══════════════════════════════════════════
         COLUMNA DERECHA — scrollable
         Frases animadas + texto + botón
    ═══════════════════════════════════════════ -->
    <div class="about-right md:w-[60%] flex flex-col justify-center py-16 md:pt-[38vh] md:pb-[18vh]">

      <!-- BLOQUE DE FRASES con "Nos" viajero -->
      <div class="about-phrases-wrapper relative mb-14">

        <!-- "Nos" — se desplaza verticalmente con el scroll -->
        <span class="about-we" aria-hidden="true" style="font-family: inter display; font-size: 58px; font-weight: 600;">Nos</span>

        <!-- 4 frases sangradas -->
        <div class="about-phrases-list">
          <div class="about-phrase-line" style="font-size: 58px; font-weight: 600; font-family: inter display;">adaptamos al cliente.</div>
          <div class="about-phrase-line" style="font-size: 58px; font-weight: 600; font-family: inter display;">fabricamos a medida.</div>
          <div class="about-phrase-line" style="font-size: 58px; font-weight: 600; font-family: inter display;">garantizamos calidad.</div>
          <div class="about-phrase-line" style="font-size: 58px; font-weight: 600; font-family: inter display">montamos en obra.</div>
        </div>

      </div>

      <!-- Párrafos de texto -->
      <div class="about-body max-w-[560px]">
        <p class="font-inter text-base md:text-lg text-slate-800 leading-relaxed mb-8">
          Acompañamos cada proyecto desde el primer boceto hasta el montaje final. Con más de veinte años en Casariche y toda la provincia de Sevilla, trabajamos codo a codo con particulares y empresas para superar siempre las expectativas.
        </p>

        <p class="font-inter text-base md:text-lg text-slate-800 leading-relaxed mb-12">
          Aunque la resistencia de nuestras estructuras es innegociable, cada trabajo tiene su propio carácter, moldeado por las aspiraciones del cliente y el potencial infinito del acero.
        </p>

        <!-- Botón negro pill -->
        <a
          href="#presupuesto"
          class="font-sans inline-flex items-center gap-3 bg-slate-900 text-white text-xs font-bold tracking-widest uppercase rounded-full px-8 py-4 hover:bg-slate-700 transition-colors duration-300"
        >
          <span class="inline-block w-2 h-2 rounded-full bg-white/50 flex-shrink-0"></span>
          Solicitar presupuesto
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  /* ─── LEFT column sticky ─── */
  @media (min-width: 768px) {
    .about-left {
      position: sticky;
      top: 0;
      height: 100vh;
      align-self: flex-start;
    }
  }

  /* ─── Título grande izquierda ─── */
  .about-title {
    font-size: clamp(3.5rem, 7vw, 6.5rem);
  }

  /* ─── Imagen: arranca negra, aclara con scroll ─── */
  .about-img {
    filter: brightness(0.08);
    transition: filter 0.08s linear;
    will-change: filter;
  }

  /* ─── Frases: tamaño igual en ambas columnas ─── */
  .about-phrases-wrapper {
    position: relative;
  }

  /* Sangría para dejar espacio al "Nos" */
  .about-phrases-list {
    margin-left: clamp(3.2rem, 8vw, 7rem);
  }

  .about-phrase-line {
    font-family: 'Karma', serif;
    font-size: clamp(2.4rem, 5.5vw, 5rem);
    font-weight: 700;
    color: #0f172a;
    line-height: 1.1;
  }

  /* "Nos" absoluto, viaja verticalmente */
  .about-we {
    position: absolute;
    left: 0;
    top: 0;
    font-family: 'Karma', serif;
    font-size: clamp(2.4rem, 5.5vw, 5rem);
    font-weight: 700;
    color: #0f172a;
    line-height: 1.1;
    white-space: nowrap;
    will-change: transform;
    pointer-events: none;
  }

  /* ─── Body text reveal ─── */
  .about-body {
    opacity: 0;
    transform: translateY(24px);
    transition: opacity 1.1s cubic-bezier(0.22, 1, 0.36, 1),
                transform 1.1s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .about-body.visible {
    opacity: 1;
    transform: translateY(0);
  }
</style>

<script>
  (() => {
    const img       = document.querySelector<HTMLElement>('.about-img');
    const weEl      = document.querySelector<HTMLElement>('.about-we');
    const lines     = Array.from(document.querySelectorAll<HTMLElement>('.about-phrase-line'));
    const bodyEl    = document.querySelector<HTMLElement>('.about-body');
    const imgWrapper = document.querySelector<HTMLElement>('.about-img-wrapper');

    /* ─── 1. Imagen: brightness ligada al scroll ─────────────────────
       Empieza en brightness(0.08) (casi negra).
       Aclara hasta brightness(1) conforme el usuario scrollea.
    ─────────────────────────────────────────────────────────────────── */
    const updateImg = () => {
      if (!img || !imgWrapper) return;
      const rect    = imgWrapper.getBoundingClientRect();
      const viewH   = window.innerHeight;
      // progress: 0 cuando la imagen entra por abajo, 1 cuando su centro llega al centro del viewport
      const progress = 1 - (rect.bottom / (viewH + rect.height));
      const clamped  = Math.max(0, Math.min(1, progress * 2.5)); // se aclara rápido
      const brightness = 0.08 + clamped * 0.92; // de 0.08 a 1.0
      img.style.filter = `brightness(${brightness})`;
    };

    /* ─── 2. "Nos" scroll-driven ─────────────────────────────────────
       Se desplaza de la línea 0 a la línea 3 mientras el usuario scrollea
       por el bloque de frases.
    ─────────────────────────────────────────────────────────────────── */
    const updateWe = () => {
      if (!weEl || !lines.length) return;
      const lineH      = lines[0].offsetHeight;
      const totalLines = lines.length; // 4

      // Tomamos la posición del bloque de frases como referencia
      const wrapperEl  = document.querySelector<HTMLElement>('.about-phrases-wrapper');
      if (!wrapperEl) return;
      const wRect  = wrapperEl.getBoundingClientRect();
      const viewH  = window.innerHeight;

      // Empieza a moverse cuando el bloque entra al 70% del viewport desde abajo
      // Termina cuando el bloque está completamente visible
      const startY = viewH * 0.65;
      const raw    = startY - wRect.top;
      const travel = lineH * (totalLines - 1);
      const progress = Math.max(0, Math.min(1, raw / (travel + lineH * 0.8)));
      const targetY  = progress * lineH * (totalLines - 1);

      weEl.style.transform = `translateY(${targetY}px)`;
    };

    /* ─── 3. Body text IntersectionObserver ─── */
    if (bodyEl) {
      const obs = new IntersectionObserver(
        ([entry]) => { if (entry.isIntersecting) bodyEl.classList.add('visible'); },
        { rootMargin: '0px 0px -8% 0px', threshold: 0.1 }
      );
      obs.observe(bodyEl);
    }

    /* ─── Scroll listener ─── */
    const onScroll = () => {
      updateImg();
      updateWe();
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // estado inicial
  })();
</script>