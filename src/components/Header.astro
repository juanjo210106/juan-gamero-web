---
// src/components/Header.astro
---
<header class="absolute top-0 left-0 w-full z-50 text-white py-6 px-8 md:px-16 flex justify-between items-center">
  <div class="flex items-center gap-2 cursor-pointer">
    <span class="text-xl font-semibold tracking-wide">Juan Gamero</span>
  </div>

  <nav class="hidden md:flex gap-8 text-sm font-medium font-sans" style="font-weight: 600;">
    <a href="#servicios" class="relative group text-gray-200 hover:text-white transition-colors">
      Servicios
      <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-white transition-all duration-300 group-hover:w-full"></span>
    </a>
    <a href="#proyectos" class="relative group text-gray-200 hover:text-white transition-colors">
      Proyectos
      <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-white transition-all duration-300 group-hover:w-full"></span>
    </a>
    <a href="#nosotros" class="relative group text-gray-200 hover:text-white transition-colors">
      Nosotros
      <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-white transition-all duration-300 group-hover:w-full"></span>
    </a>
  </nav>

  <div class="hidden md:flex items-center gap-4 font-sans">
    <a href="#presupuesto" class="px-6 py-2 text-sm font-medium border border-white text-white rounded-full bg-transparent hover:bg-white hover:text-black transition-all duration-300">
      Presupuesto Gratis
    </a>
  </div>
</header>