---
// src/layouts/Layout.astro
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Karma:wght@400;600;700&display=swap" rel="stylesheet">
	</head>
	<body class="antialiased bg-white overflow-x-hidden" style="font-family: 'Karma', serif;">
		<slot />
		<script>
			const initObserver = () => {
				const observerOptions = {
					root: null,
					rootMargin: '0px 0px -50px 0px', 
					threshold: 0 // La magia: salta en el momento exacto que asoma en pantalla
				};

				const observer = new IntersectionObserver((entries) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							// Cuando el usuario hace scroll hacia abajo y lo ve: aparece suavemente
							entry.target.classList.add('active');
						} else {
							// Cuando el usuario hace scroll hacia arriba y lo deja atrás: desaparece para estar listo la próxima vez
							entry.target.classList.remove('active');
						}
					});
				}, observerOptions);

				// Buscamos todas las clases de animación
				const reveals = document.querySelectorAll('.reveal-text, .reveal-card');
				reveals.forEach((el) => observer.observe(el));
			};

			// Ejecutamos
			initObserver();
		</script>
	</body>
</html>